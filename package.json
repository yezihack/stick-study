{
  "name": "stick-study",
  "version": "1.0.8",
  "description": "学習打卡 - Daily study check-in app",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "cap:sync": "cap sync android",
    "gen:splash": "node scripts/gen_splash.mjs",
    "apk": "npm run build && npm run cap:sync && npm run gen:splash && cd android && gradlew.bat assembleRelease",
    "apk:debug": "npm run build && npm run cap:sync && npm run gen:splash && cd android && gradlew.bat assembleDebug"
  },
  "keywords": [
    "study",
    "tracker",
    "vue3",
    "dexie"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@capacitor-community/media": "^9.1.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/status-bar": "^8.0.2",
    "dexie": "^3.2.7",
    "vue": "^3.5.35",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-vue": "^9.33.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vue-tsc": "^2.2.12"
  }
}
